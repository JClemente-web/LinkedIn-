# Copie este arquivo para .env e preencha antes de rodar `docker compose up -d`

# Chave que criptografa as credenciais salvas no n8n.
# Gere uma com:  openssl rand -hex 24
# NÃO PERCA esta chave — sem ela as credenciais salvas ficam ilegíveis.
N8N_ENCRYPTION_KEY=

# Fuso horário dos agendamentos (Seg/Qua/Sex 9h, diário 8h etc.)
GENERIC_TIMEZONE=America/Sao_Paulo
