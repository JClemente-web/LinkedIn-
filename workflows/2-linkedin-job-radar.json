      "id": "schedule-2",
      "name": "Todo dia às 8h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "areas-1",
      "name": "Definir buscas (3 áreas)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 0],
      "parameters": {
        "jsCode": "// Uma busca por área — edite as palavras-chave à vontade.\n// Cada item vira uma chamada separada à Apify.\nreturn [\n  {\n    json: {\n      area: 'RH',\n      keywords: '\"recursos humanos\" OR recrutamento OR \"departamento pessoal\" OR \"analista de rh\" OR \"assistente de rh\"'\n    }\n  },\n  {\n    json: {\n      area: 'Química',\n      keywords: 'químico OR química OR laboratório OR \"técnico químico\"'\n    }\n  },\n  {\n    json: {\n      area: 'Caldeiraria/Offshore/IRATA',\n      keywords: 'caldeireiro OR caldeiraria OR offshore OR embarcado OR plataforma OR IRATA OR \"acesso por corda\" OR \"alpinismo industrial\" OR \"trabalho em altura\"'\n    }\n  },\n  {\n    json: {\n      area: 'Programação/TI',\n      keywords: 'desenvolvedor OR programador OR \"suporte técnico\" OR \"analista de dados\" OR automação'\n    }\n  }\n];"
      }
    },
    {
      "id": "apify-1",
      "name": "Buscar vagas (Apify)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 0],
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/k1ra~linkedin-jobs-scraper/run-sync-get-dataset-items",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ keywords: $json.keywords, location: \"Brazil\", postedWithin: \"24h\", excludeRecruiters: false, maxResults: 50, includeDescription: true }) }}",
        "options": {
          "timeout": 300000
        }
      },
      "notesInFlow": true,
      "notes": "Roda 1x por área definida no node anterior. Credencial Header Auth: Authorization = Bearer SEU_TOKEN_APIFY"
    },
    {
      "id": "dedupe-1",
      "name": "Remover vagas já vistas",
      "type": "n8n-nodes-base.removeDuplicates",
      "typeVersion": 2,
      "position": [600, 0],
      "parameters": {
        "operation": "removeItemsSeenInPreviousExecutions",
        "logic": "removeItemsWithAlreadySeenKeyValues",
        "dedupeValue": "={{ $json.jobUrl }}",
        "options": {
          "historySize": 5000
        }
      }
    },
