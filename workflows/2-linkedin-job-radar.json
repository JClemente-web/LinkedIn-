{
  "name": "2 · LinkedIn — Radar de vagas BI/Dados",
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "nodes": [
    {
      "id": "schedule-2",
      "name": "Todo dia às 8h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        0
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "areas-1",
      "name": "Definir buscas (BI)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        0
      ],
      "parameters": {
        "jsCode": "// Radar focado na área mais forte do LinkedIn: BI / Análise de Dados\nreturn [\n  {\n    json: {\n      area: 'BI/Power BI',\n      keywords: '\"power bi\" OR \"analista de bi\" OR \"assistente de bi\" OR \"analista de business intelligence\" OR dashboard'\n    }\n  },\n  {\n    json: {\n      area: 'Analista de Dados',\n      keywords: '\"analista de dados\" OR \"assistente de dados\" OR \"analista de dados júnior\" OR \"estágio dados\" OR \"estágio power bi\"'\n    }\n  },\n  {\n    json: {\n      area: 'SQL/Excel BI',\n      keywords: 'sql AND (excel OR \"power bi\" OR dashboard OR indicadores OR kpi)'\n    }\n  }\n];"
      }
    },
    {
      "id": "apify-1",
      "name": "Buscar vagas (Apify)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/k1ra~linkedin-jobs-scraper/run-sync-get-dataset-items",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ keywords: $json.keywords, location: \"Brazil\", postedWithin: \"24h\", excludeRecruiters: false, maxResults: 50, includeDescription: true }) }}",
        "options": {
          "timeout": 300000
        }
      },
      "notesInFlow": true,
      "notes": "Roda 1x por área definida no node anterior. Credencial Header Auth: Authorization = Bearer SEU_TOKEN_APIFY"
    },
    {
      "id": "dedupe-1",
      "name": "Remover vagas já vistas",
      "type": "n8n-nodes-base.removeDuplicates",
      "typeVersion": 2,
      "position": [
        600,
        0
      ],
      "parameters": {
        "operation": "removeItemsSeenInPreviousExecutions",
        "logic": "removeItemsWithAlreadySeenKeyValues",
        "dedupeValue": "={{ $json.jobUrl }}",
        "options": {
          "historySize": 5000
        }
      }
    },
